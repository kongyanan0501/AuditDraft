# 复制为 .env.local 并填写真实值。切勿提交 .env.local。

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 仅服务端使用，绝不暴露到浏览器
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 默认 provider: openai | anthropic | qwen
LLM_PROVIDER=openai
# 规则-only 降级：跳过 LLM/RAG，仅解析+规则+模板底稿（额度耗尽/演示兜底）
# AUDIT_DEGRADED_MODE=rules_only
# 兼容别名：DEMO_RULES_ONLY=1

# 重要性（可选；默认 500000 / 75% / 5%）
# MATERIALITY_PLANNING=500000
# MATERIALITY_PERFORMANCE=375000
# MATERIALITY_TRIVIAL=25000

# 规则阈值（可选；调参台 UI 可覆盖预览）
# RULE_APPROVAL_THRESHOLD=10000
# RULE_SPLIT_NEAR_RATIO=0.8
# RULE_ZSCORE_THRESHOLD=2
# 可选：覆盖默认模型
# OPENAI_MODEL=gpt-4.1-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Qwen（通义千问，OpenAI 兼容接口；LLM_PROVIDER=qwen 时必填）──
# 官方命名 DASHSCOPE_API_KEY（兼容回退 QWEN_API_KEY）
DASHSCOPE_API_KEY=
# 可选：端点（默认 DashScope 兼容端点）；用自建/第三方网关时改这里
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选：模型（默认 qwen-plus）
# QWEN_MODEL=qwen-plus


# ── RAG (Pinecone) ────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=
# Embedding provider：openai | dashscope（未设时若 LLM_PROVIDER=qwen 则自动用 dashscope）
# dashscope 复用 DASHSCOPE_API_KEY，无需额外 OpenAI key
# EMBEDDING_PROVIDER=dashscope
# 可选：embedding 模型（openai 默认 text-embedding-3-small；dashscope 默认 text-embedding-v4）
# 维度固定为 1536（须与 Pinecone 索引一致）
# EMBEDDING_MODEL=text-embedding-v4
# 可选：建索引时的 serverless 部署位置（仅 seed 脚本首次建索引用）
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
