# 复制为 .env.local 并填写真实值。切勿提交 .env.local。

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 仅服务端使用，绝不暴露到浏览器
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 默认 provider: openai | anthropic
LLM_PROVIDER=openai

# ── RAG (Pinecone) ────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=
