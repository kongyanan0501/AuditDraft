# 复制为 .env.local 并填写真实值。切勿提交 .env.local。

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 仅服务端使用，绝不暴露到浏览器
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 默认 provider: openai | anthropic
LLM_PROVIDER=openai
# 可选：覆盖默认模型
# OPENAI_MODEL=gpt-4.1-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── RAG (Pinecone) ────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=
# 可选：embedding 模型（维度需与索引一致）
# EMBEDDING_MODEL=text-embedding-3-small
# 可选：建索引时的 serverless 部署位置（仅 seed 脚本首次建索引用）
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
